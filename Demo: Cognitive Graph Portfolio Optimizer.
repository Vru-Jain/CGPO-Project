{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# --- SIMULATION OF CGPO LOGIC ---\n\n# 1. Generate Dummy Market Data (10 Stocks, 100 Days)\nnp.random.seed(42)\nassets = ['AAPL', 'MSFT', 'GOOGL', 'AMZN', 'TSLA', 'JPM', 'V', 'JNJ', 'WMT', 'PG']\ndata = pd.DataFrame(np.random.randn(100, 10), columns=assets)\n\n# 2. Calculate Correlation Matrix (The \"Edges\" of your graph)\ncorr_matrix = data.corr()\n\n# 3. Build the Graph\nG = nx.Graph()\n\n# Add nodes (Assets)\nfor asset in assets:\n    G.add_node(asset)\n\n# Add edges (Draw a line if correlation is strong > 0.1)\nfor i in range(len(assets)):\n    for j in range(i+1, len(assets)):\n        asset_i = assets[i]\n        asset_j = assets[j]\n        correlation = corr_matrix.iloc[i, j]\n        \n        # LOGIC: Only link assets that move together (Thresholding)\n        if abs(correlation) > 0.1: \n            G.add_edge(asset_i, asset_j, weight=correlation)\n\nprint(f\"✅ Graph Construction Complete: {G.number_of_nodes()} Nodes, {G.number_of_edges()} Edges.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-11T10:02:14.738448Z","iopub.execute_input":"2026-01-11T10:02:14.738932Z","iopub.status.idle":"2026-01-11T10:02:14.749098Z","shell.execute_reply.started":"2026-01-11T10:02:14.738895Z","shell.execute_reply":"2026-01-11T10:02:14.748006Z"}},"outputs":[{"name":"stdout","text":"✅ Graph Construction Complete: 10 Nodes, 13 Edges.\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"# 4. Visualize the Portfolio Graph\nplt.figure(figsize=(12, 8))\n\n# Layout: Organize nodes based on connection strength\npos = nx.spring_layout(G, seed=42)\n\n# Draw Nodes (Assets)\nnx.draw_networkx_nodes(G, pos, node_size=2000, node_color='#1f77b4', alpha=0.9)\n\n# Draw Edges (Correlations) - Thicker line = Stronger correlation\nweights = [G[u][v]['weight'] * 5 for u,v in G.edges()]\nnx.draw_networkx_edges(G, pos, width=weights, alpha=0.5, edge_color='gray')\n\n# Labels\nnx.draw_networkx_labels(G, pos, font_size=12, font_color='white', font_weight='bold')\n\nplt.title(\"Cognitive Graph Portfolio Optimizer (CGPO) - Asset Clustering Demo\", fontsize=15)\nplt.axis('off') # Hide axis\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-11T10:02:14.750384Z","iopub.execute_input":"2026-01-11T10:02:14.750718Z","iopub.status.idle":"2026-01-11T10:02:15.087467Z","shell.execute_reply.started":"2026-01-11T10:02:14.750695Z","shell.execute_reply":"2026-01-11T10:02:15.086166Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x800 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":9}]}